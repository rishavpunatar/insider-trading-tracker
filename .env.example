APP_ENV=development
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./data/insider_tracker.db
DATA_DIR=./data
HTTP_USER_AGENT=InsiderTradingTracker/0.1 your-email@example.com
